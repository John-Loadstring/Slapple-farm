local Luva1 = CFrame.new(-418.3, 89.2, -28.4)
local Luva2 = CFrame.new(-432.7, 50.3, -24.1)
local Luva3 = CFrame.new(-415.4, 52, 14.8)
local Luva4 = CFrame.new(-407, 51.4, 13.1)
local Luva5 = CFrame.new(-397.6, 57.2, 20.4)
local Luva6 = CFrame.new(-384.6, 52.4, 17.7)
local Luva7 = CFrame.new(-371.6, 57.6, 13.1)
local Luva8 = CFrame.new(-412.2, 50.3, -43.6)
local Luva9 = CFrame.new(-372.4, 52.2, -28.8)
local Luva10 = CFrame.new(-365.8, 52.6, -28)

local function andarAleatorio(humanoid, hrp)
    local offset = Vector3.new(math.random(-5,5), 0, math.random(-5,5))
    humanoid:MoveTo(hrp.Position + offset)
    humanoid.MoveToFinished:Wait()
end

local function teleportarOutroServidor()
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
    local data = HttpService:JSONDecode(game:HttpGet(url))

    for _,server in ipairs(data.data) do
        if server.playing < server.maxPlayers and server.id ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(placeId, server.id, player)
            return
        end
    end

    TeleportService:Teleport(placeId, player)
end

local function Iniciar()
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")

    local alvo = workspace.Lobby:WaitForChild("Teleport1")

    humanoid:MoveTo(alvo.Position)
    humanoid.MoveToFinished:Wait()

    andarAleatorio(humanoid, hrp)
    task.wait(0.5)

    local lista = {Luva1, Luva2, Luva3, Luva4, Luva5, Luva6, Luva7, Luva8, Luva9, Luva10}

    for i,cf in ipairs(lista) do
        hrp.CFrame = cf
        task.wait(0.2)
        if i % 2 == 0 then
            andarAleatorio(humanoid, hrp)
        end
    end

    andarAleatorio(humanoid, hrp)
    task.wait(2)

    teleportarOutroServidor()

    task.wait(math.random(2,4))

    local character2 = player.Character or player.CharacterAdded:Wait()
    local humanoid2 = character2:WaitForChild("Humanoid")
    local hrp2 = character2:WaitForChild("HumanoidRootPart")

    andarAleatorio(humanoid2, hrp2)

    task.wait(1)

    teleportarOutroServidor()
end

task.spawn(function()
    while true do
        local loading = playerGui:FindFirstChild("LoadingIndicator", true) 
        
        if not loading or loading.Visible == false then
            Iniciar()
            break 
        end
        
        task.wait(0.5)
    end
end)
