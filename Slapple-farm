local function teleportarOutroServidor()
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"
    local success, data = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)

    if success and data and data.data then
        local servers = {}
        for _,server in ipairs(data.data) do
            if server.playing < server.maxPlayers and server.id ~= game.JobId then
                table.insert(servers, server.id)
            end
        end
        if #servers > 0 then
            local escolhido = servers[math.random(1, #servers)]
            TeleportService:TeleportToPlaceInstance(placeId, escolhido, player)
            return
        end
    end
    TeleportService:Teleport(placeId, player)
end

local function travarInicial()
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local pos = hrp.CFrame
    local rodando = true

    task.spawn(function()
        while rodando do
            hrp.CFrame = pos
            task.wait()
        end
    end)

    while true do
        local loading = playerGui:FindFirstChild("LoadingIndicator", true)
        if not loading or loading.Visible == false then
            rodando = false
            break
        end
        task.wait(0.2)
    end
end

local function Iniciar()
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local hrp = character:WaitForChild("HumanoidRootPart")
    local lobby = workspace:WaitForChild("Lobby")

    while hrp:IsDescendantOf(lobby) or (hrp.Position - lobby.Position).Magnitude < 1 do
        humanoid:Move(Vector3.zero)
        task.wait(0.1)
    end

    for _,cf in ipairs(lista) do
        hrp.CFrame = cf
        local offset = Vector3.new(math.random(-2,2), 0, math.random(-2,2))
        humanoid:MoveTo(hrp.Position + offset)
        task.wait(0.1)
    end

    teleportarOutroServidor()
end

task.spawn(function()
    travarInicial()
    Iniciar()
end)
